rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Solo el staff admin. Antes se usaba `request.auth != null`, pero el
    // registro público de Auth está habilitado: CUALQUIERA podía crear una
    // cuenta con la API key pública y leer/escribir estos datos. Ahora se exige
    // ser el admin — vía custom claim `admin:true` (preferido, permite sumar
    // staff sin tocar reglas) o el UID del admin actual como respaldo inmediato.
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.uid == 'VUm858rENuNVzB4MAMtzLnGb1A63'
      );
    }

    // Catálogo público: lectura libre, escritura solo admin
    match /services/{id}   { allow read: if true; allow write: if isAdmin(); }
    match /staff/{id}      { allow read: if true; allow write: if isAdmin(); }
    match /businessInfo/{id}{ allow read: if true; allow write: if isAdmin(); }

    // Reservas: el público puede CREAR (validado), solo admin lee/edita/borra
    match /bookings/{id} {
      allow read, update, delete: if isAdmin();
      allow create: if isValidBooking();
    }
    function isValidBooking() {
      let d = request.resource.data;
      return d.status == 'pending'
        && d.name is string  && d.name.size() > 1
        && d.email is string && d.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
        && d.phone is string && d.phone.size() >= 7
        && d.svcId is string && d.barberId is string
        && d.date is string  && d.time is string
        && d.code is string
        && d.club is string  && (d.club == 'member' || d.club == 'guest');
    }

    // Clientes (v19): nombre, contacto, historial de visitas y fotos (PII).
    // Nunca hay escritura pública directa — el único creador/actualizador es
    // la Cloud Function onBookingCreated (Admin SDK, no sujeta a estas reglas).
    match /patients/{id} { allow read, write: if isAdmin(); }

    // Log de actividad: solo admin
    match /adminLog/{id} { allow read, write: if isAdmin(); }
  }
}
